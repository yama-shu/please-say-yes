# アプリの設定（すべて任意。未設定ならデフォルト値が使われる）
# ビルド時に読み込まれる（Vite の import.meta.env）。変更後は dev サーバの再起動が必要。

# 画面に表示する質問文
# VITE_QUESTION_TEXT=「はい」と言ってくれますか？

# 完了画面に表示するメッセージ
# VITE_COMPLETE_TEXT=ありがとう。そう言ってくれると思ってた。

# 「はい」ボタンの初期サイズ（ビューポートに対する割合 0〜1）
# VITE_YES_INITIAL_RATIO=0.12

# 「いいえ」1 押下ごとの拡大倍率（1 より大きい値）
# VITE_YES_GROWTH_RATE=1.4

# 拡大の上限（ビューポートに対する割合。1 = 画面全体）
# VITE_YES_MAX_RATIO=1

# 煽り文言の段階（JSON 配列。count 回以上の「いいえ」で text を表示）
# VITE_TAUNT_STAGES=[{"count":2,"text":"本当に？"},{"count":4,"text":"考え直してほしい"},{"count":6,"text":"悪いことは言わないから"},{"count":7,"text":"もう逃げられないよ？"}]
